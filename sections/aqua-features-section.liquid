<div class="page-width" style="max-width: 1200px; margin: 0 auto; text-align: center;">
  <div class="nv-features">
    {% for block in section.blocks %}
      <div class="nv-features__item" {{ block.shopify_attributes }}>
        <div class="nv-features__icon">
          {% if block.settings.custom_svg != blank %}
            {{ block.settings.custom_svg }}
          {% elsif block.settings.image != blank %}
            {{ block.settings.image | image_url: width: 112 | image_tag: alt: block.settings.title }}
          {% endif %}
        </div>
        <p class="nv-features__title">{{ block.settings.title | newline_to_br }}</p>
      </div>
      {% unless forloop.last %}
        <div class="nv-features__divider"></div>
      {% endunless %}
    {% endfor %}
  </div>
</div>

<style>
.nv-features {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0;
  padding: 32px 0;
  background: {{ section.settings.bg_color | default: '#ffffff' }};
  margin: 0;
  width: 100%;
  box-sizing: border-box;
}

.nv-features__item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 16px;
  flex: 1;
  text-align: center;
  padding: 0 16px;
}

.nv-features__icon {
  width: 56px;
  height: 56px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nv-features__icon svg {
  width: 100%;
  height: 100%;
}

.nv-features__icon img {
  max-width: 100%;
  max-height: 100%;
  object-fit: contain;
}

.nv-features__title {
  font-size: 14px;
  font-weight: 600;
  color: #1B3A6B;
  line-height: 1.5;
  margin: 0;
}

.nv-features__divider {
  width: 1px;
  height: 70px;
  background: #e5e7eb;
  flex-shrink: 0;
}

@media (max-width: 600px) {
  .nv-features {
    padding: 20px 0;
  }
  .nv-features__item {
    padding: 0 4px;
    gap: 10px;
  }
  .nv-features__title {
    font-size: 11px;
  }
  .nv-features__icon {
    width: 34px;
    height: 34px;
  }
  .nv-features__divider {
    height: 40px;
  }
}

.nv-no-padding {
  padding-left: 0 !important;
  padding-right: 0 !important;
}
</style>

{% schema %}
{
  "name": "Aqua Features Section",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#ffffff"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        {
          "type": "textarea",
          "id": "custom_svg",
          "label": "Custom SVG Icon",
          "info": "Paste SVG code here. Overrides image if present."
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Icon Image",
          "info": "Used if no custom SVG is provided."
        },
        {
          "type": "textarea",
          "id": "title",
          "label": "Title",
          "default": "Feature Title"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Aqua Features Section",
      "blocks": [
        {
          "type": "feature",
          "settings": {
            "title": "Anti-humidité",
            "custom_svg": "<svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#1B3A6B\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\">\n  <path d=\"M12 2L4 5.5v6.5c0 5 3.5 9.5 8 11 4.5-1.5 8-6 8-11V5.5L12 2z\"/>\n  <path d=\"M12 8c0 0-3 2.5-3 4.5a3 3 0 0 0 6 0C15 10.5 12 8 12 8z\" fill=\"#1B3A6B\" stroke=\"none\"/>\n</svg>"
          }
        },
        {
          "type": "feature",
          "settings": {
            "title": "Invisible\nsans trace",
            "custom_svg": "<svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#1B3A6B\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\">\n  <ellipse cx=\"12\" cy=\"12\" rx=\"9\" ry=\"6\"/>\n  <circle cx=\"12\" cy=\"12\" r=\"2.5\"/>\n  <line x1=\"3\" y1=\"3\" x2=\"21\" y2=\"21\"/>\n</svg>"
          }
        },
        {
          "type": "feature",
          "settings": {
            "title": "Application\nrapide",
            "custom_svg": "<svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#1B3A6B\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\">\n  <path d=\"M13 2L4.5 13.5H11L10 22L19.5 10.5H13L13 2z\"/>\n</svg>"
          }
        },
        {
          "type": "feature",
          "settings": {
            "title": "Multi-\nsurfaces",
            "custom_svg": "<svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#1B3A6B\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\">\n  <rect x=\"3\" y=\"3\" width=\"7\" height=\"7\" rx=\"1\"/>\n  <rect x=\"14\" y=\"3\" width=\"7\" height=\"7\" rx=\"1\"/>\n  <rect x=\"3\" y=\"14\" width=\"7\" height=\"7\" rx=\"1\"/>\n  <rect x=\"14\" y=\"14\" width=\"7\" height=\"7\" rx=\"1\"/>\n</svg>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
