{{ 'custom-cart.css' | asset_url | stylesheet_tag }}

<div class="custom-cart">
  <div class="custom-cart__header">
    <h1 class="custom-cart__title">Your Cart</h1>
    <a href="{{ routes.all_products_collection_url }}">Continue Shopping</a>
  </div>

  <div id="custom-cart-empty" style="display: none;">
    <h2>Your cart is currently empty.</h2>
    <a href="{{ routes.all_products_collection_url }}">Start Shopping</a>
  </div>

  <form action="{{ routes.cart_url }}" method="post" id="custom-cart-form" novalidate>
    <div class="custom-cart-layout">
      <div class="custom-cart-items-wrapper" id="custom-cart-items-wrapper">
        <div class="custom-cart-header-labels">
          <div>Product</div>
          <div>Price</div>
          <div>Quantity</div>
          <div style="text-align: right;">Total</div>
        </div>
        
        <div id="custom-cart-items">
          <!-- Cart items injected by JS -->
        </div>
      </div>

      <div class="custom-cart-summary">
        <div class="custom-cart-summary__row">
          <span>Subtotal (<span id="custom-cart-count">{{ cart.item_count }}</span> items)</span>
          <span id="custom-cart-subtotal">{{ cart.total_price | money }}</span>
        </div>
        
        <p style="font-size: 13px; color: #666; margin-bottom: 25px;">Taxes and shipping calculated at checkout.</p>

        <div class="custom-cart-note">
          <label for="custom-cart-note">Add a note to your order</label>
          <textarea name="note" id="custom-cart-note">{{ cart.note }}</textarea>
          <button type="button" id="save-note-btn" onclick="updateCartNote()">Save Note</button>
        </div>

        <button type="submit" name="checkout" class="checkout-btn">Checkout</button>
      </div>
    </div>
  </form>
</div>

{% schema %}
{
  "name": "Custom Cart",
  "settings": []
}
{% endschema %}
